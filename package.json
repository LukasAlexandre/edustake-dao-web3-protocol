{
  "name": "edustake-dao-web3-protocol",
  "version": "1.0.0",
  "description": "MVP academico Web3 com ERC-20, ERC-721, staking, DAO e oracle Chainlink.",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "node": "hardhat node",
    "code": "npm run node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "frontend:dev": "npm --prefix frontend run dev",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "mint:nft": "hardhat run scripts/mintNFT.js --network sepolia",
    "stake": "hardhat run scripts/stake.js --network sepolia",
    "vote": "hardhat run scripts/vote.js --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.10"
  },
  "dependencies": {
    "@chainlink/contracts": "1.3.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2"
  }
}
